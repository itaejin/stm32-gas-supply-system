						for(int i = 0; i < 6; i++) {  // 6워드 = 12바이트
			                // 배열 경계 체크
			                if((7 + i*2 + 1) < MAX_DLEN && (7 + i*2 + 1) < rcntDataIdx) {
			                	uint16_t wordData = (Data[PrevIdx][7 + i*2] << 8) + Data[PrevIdx][8 + i*2];
			                    // 🔥 바이트 순서 수정: Modbus는 Big-Endian
			                	GasName[i*2+1] = (uint8_t)((wordData >> 8) & 0xFF);  // 상위 바이트
								GasName[i*2] = (uint8_t)(wordData & 0xFF);           // 하위 바이트
			                } else {
			                    // 배열 경계 초과 에러
			                    DebugStep = 3900;
			                    DebugValue = i;
			                    DebugAddr = rcntDataIdx;
			                    goto Modbus_Reply_Echo;
			                }
						}
						GasName[11] = '\0';  // null 종료
						DebugValue = ((uint16_t*)GasName)[0];  // 첫 번째 워드 확인
			            DebugAddr = ((uint16_t*)GasName)[1];  // 두 번째 워드
						SaveFlashParam();
//			            DebugStep = 3200; // 저장 후
					} else {
			            DebugStep = 2999; // 범위 밖 주소
			            DebugValue = NewAddr;
			        }
				}
				else if(NewByteCount == 6) {  // ← 이 조건 추가
					// 가스 단위 변경 (주소 6-8)
					if(NewAddr >= 6 && NewAddr <= 8) {
						DebugStep = 4000 + NewAddr;  // 가스 단위 변경 추적 (4006~4008)
						// 🔥 6바이트 전체 데이터 추출
						for(int i = 0; i < 3; i++) {  // 3워드 = 6바이트
							uint16_t wordData = (Data[PrevIdx][7 + i*2] << 8) + Data[PrevIdx][8 + i*2];
							GasUnit[i*2+1] = (uint8_t)((wordData >> 8) & 0xFF);
							GasUnit[i*2] = (uint8_t)(wordData & 0xFF);
						}
						GasUnit[5] = '\0';

						DebugValue = ((uint16_t*)GasUnit)[0];
/*
						uint16_t* pGasUnit = (uint16_t*)GasUnit;
						pGasUnit[NewAddr-6] = NewData;
*/
						SaveFlashParam();  // 플래시 저장
					}
				}

				else if(NewByteCount==2) {
					// 🆕 디버깅: 여기까지 들어오는지 확인
			        DebugStep = 1000;  // 기본 진입
			        DebugAddr = NewAddr;   // 실제 받은 주소
					DebugValue = NewData;  // 실제 받은 데이터
					// 🆕 비밀번호 입력창에서 비밀번호 입력 시
//					if(NewWindow == PW_Input && NewAddr == 90) {  // 비밀번호 입력창
			        if(NewWindow == PW_Input) {  // 비밀번호 입력창
						DebugStep = 1150;
						Password.CurValue = NewData;  // 키패드로 입력된 값
						DebugAddr = NewData;
						DebugValue = Password.CurValue;
					}
					// 🆕 수정: 실제 받는 주소로 처리
					else if(NewAddr == 91) {  // HMI의 91, 92가 90, 91로 들어옴
						DebugStep = 2091;
						// 즉시 모든 비밀번호 필드 업데이트
						Password.ChangedValue = NewData;
//						Password.CurValue = NewData;
						Password.SavedValue = NewData;
						SaveFlashParam();
					}
					else if(NewWindow == Config) {
						// PT1 데이터 변경 (주소 9-18)
						if(NewAddr >= 9 && NewAddr <= 18) {
					        DebugStep = 5000 + NewAddr;

							uint16_t* pPT1 = (uint16_t*)&PT1;
							pPT1[NewAddr-9] = NewData;
							SaveFlashParam();  // 플래시 저장
						}
						// PT2 데이터 변경 (주소 19-28)
						else if(NewAddr >= 19 && NewAddr <= 28) {
							uint16_t* pPT2 = (uint16_t*)&PT2;
							pPT2[NewAddr-19] = NewData;
							SaveFlashParam();  // 플래시 저장
						}
						// PT3 데이터 변경 (주소 29-35)
						else if(NewAddr >= 29 && NewAddr <= 35) {
							uint16_t* pPT3 = (uint16_t*)&PT3;
							pPT3[NewAddr-29] = NewData;
							SaveFlashParam();  // 플래시 저장
						}

//						if(NewAddr < 79) {
//							UpdateSingleWord((uint8_t*)&PT1, (uint8_t*)&NewData);
/*
							SetWord(sData, GasName, 6);
							SetWord(sData+12, GasUnit, 3);
							SetWord(sData+18, (uint8_t*)&PT1, 10);
							SetWord(sData+38, (uint8_t*)&PT2, 10);
							SetWord(sData+58, (uint8_t*)&PT3, 6);
						}
*/

						else if(NewAddr == 99) 	SetCurrentWindow(NewData);
						else if(NewAddr == 101) 	SetChangeWindow(NewData);
						else if(NewAddr == 102) 	SetAlarmWindow(NewData);
						else						goto Cmd_Not_Supported;
					} else if(NewAddr == 91)			InputPassword(NewData);
					else if(NewAddr == 99) 		SetCurrentWindow(NewData); 
					else if(NewAddr == 101) 	SetChangeWindow(NewData);
					else if(NewAddr == 102) 	SetAlarmWindow(NewData);
					else {
			            DebugStep = 9000;  // 지원되지 않는 명령
						goto Cmd_Not_Supported;
					}
				} else {
		            DebugStep = 999;  // 지원되지 않는 명령
		            DebugAddr = NewWindow;  // 현재 윈도우 상태

					goto Cmd_Not_Supported;
				}
				goto Modbus_Reply_Echo;
			} 
//------------------------------------------------------- // Record Not Yet Supported Request
			else {
Cmd_Not_Supported:
				NoRespCnt++;
				NewFunc0 = NewFunc;
				NewAddr0 = NewAddr;
				NewQnty0 = NewQnty;
				NewData = NewData;
			}
//------------------------------------------------------- // End of Modbus Send Reply:			
			PrevNewFunc = NewFunc;
			NewFunc = 0;
		}	// end of if(NewFunc)

	}
    // 🔥 맨 끝에 이 한 줄만 추가
//  if(splash_screen_active) NewWindow = 10;

    UpdateFlowLampColors();
}

