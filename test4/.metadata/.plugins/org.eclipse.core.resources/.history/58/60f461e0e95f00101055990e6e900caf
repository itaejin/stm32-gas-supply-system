// 🆕 가스량 확인램프 상태 업데이트 함수
void UpdateGasLampStatus()
{
    // PT1 가스량 상태 확인
    if(IOdata.SupplyGasLSW == 0) {  // 운전중이 아닐때
    	// 충전량이 80% 이상
    	if(PT1.Value >= PT1.MaxValue * 0.8) PT1.GasLamp = 0;  // 충전량양호
		else PT1.GasLamp = 1;  // 대기중
    } else if(IOdata.SupplyGasLSW == 1) {  // 공급중일때
        if(PT1.Value > PT1.Low) {
        	PT1.GasLamp = 2;  // 공급중
        } else if(PT1.Value > PT1.LowLow) {
        	PT1.GasLamp = 3;  // 교체준비
        } else {
        	PT1.GasLamp = 4;  // 교체알람
        }
    }

    if(IOdata.SupplyGasRSW == 0) {  // 운전중이 아닐때
    	// 충전량이 80% 이상
    	if(PT2.Value >= PT2.MaxValue * 0.8) PT2.GasLamp = 0; // 충전량양호
    	else PT2.GasLamp = 1;  // 대기중
    } else if(IOdata.SupplyGasRSW == 1) {  // 공급중일때
        if(PT2.Value > PT2.Low) {
        	PT2.GasLamp = 2;  // 공급중
        } else if(PT2.Value > PT2.LowLow) {
        	PT2.GasLamp = 3;  // 교체준비
        } else {
        	PT2.GasLamp = 4;  // 교체알람
        }
    }
}
// 👈 여기에 UpdateFlowLampColors 함수 추가
void UpdateFlowLampColors()
{
	// 🆕 시뮬레이션 모드에서 가스 값 감소 시뮬레이션
	if(simulation_mode) {
		// PT1이 공급 중이면 값을 1씩 감소
		if(IOdata.SupplyGasLSW == 1 && PT1.Value > 0) {
			static uint8_t pt1_counter = 0;
			pt1_counter++;
			if(pt1_counter >= 5) {
				PT1.Value--;
				GraphPT1.Value = PT1.Value;
				pt1_counter = 0;
			}
		}

		// PT2가 공급 중이면 값을 1씩 감소 (좀 더 천천히)
		if(IOdata.SupplyGasRSW == 1 && PT2.Value > 0) {
			static uint8_t pt2_counter = 0;
			pt2_counter++;
			// PT2는 2번에 1번씩 감소 (더 오래 지속)
			if(pt2_counter >= 5) {
				PT2.Value--;
				GraphPT2.Value = PT2.Value;
				pt2_counter = 0;
			}
		}
	}
	// 🔥 항상 그래프 값을 실제 값과 동기화
	GraphPT1.Value = PT1.Value;
	GraphPT2.Value = PT2.Value;

	// 🆕 공급 압력 체크 추가 (PT3) - [A007] PT3 최소공급알람
	if(PT3.Value < PT3.MinSValue) {
		if(!PT3_low_acknowledged) {
			IOdata.MinSuuplPressPT3 = (IOdata.UseBuzzerLamp == 0) ? 1 : 0;  // [A007] PT3 최소공급알람 ON
		}
	} else {
		IOdata.MinSuuplPressPT3 = 0;      // 공급 압력 정상 - 알림 OFF
		PT3_low_acknowledged = 0;          // 플래그 초기화
	}

	// 🆕 PT1에서 PT2로 자동 전환 로직
	if(auto_switch_enabled && IOdata.SupplyGasLSW == 1) {
		// PT1이 교체알람 수준 이하이고 PT2가 정상이면 자동 전환
		if(PT1.Value <= PT1.LowLow && PT2.Value > PT2.LowLow) {
			IOdata.SupplyGasLSW = 0;  // PT1 공급 중지
			IOdata.SupplyGasRSW = 1;  // PT2 공급 시작
			IOdata.StopGasLLamp = 1;  // PT1 정지 램프 ON
			IOdata.StopGasRLamp = 0;  // PT2 정지 램프 OFF

			// PT1 화살표 OFF
			FlowLamp.BSVelL = 0;
			FlowLamp.BSLampL = 0;
			FlowLamp.ASVelL = 0;
			FlowLamp.ASLampL = 0;

			// PT2 화살표 ON (정상 상태라면)
			if(PT2.Value > PT2.Low) {
				FlowLamp.BSVelR = 8;
				FlowLamp.BSLampR = 8;
				FlowLamp.ASVelR = 8;
				FlowLamp.ASLampR = 8;
			}
		}
	}
	// 왼쪽 가스가 공급 중일 때만 PT1 색상 업데이트
	if(IOdata.SupplyGasLSW == 1) {
		if (PT1.Value > PT1.Low) {
			FlowLamp.BSVelL = 8;
			FlowLamp.BSLampL = 8;
			FlowLamp.ASVelL = 8;
			FlowLamp.ASLampL = 8;
			// 알람 해제
			IOdata.PrepChgPT1 = 0;
			IOdata.PrepChgPT1Alarm = 0;
			// 알람 플래그 초기화
            PT1_prep_acknowledged = 0;
            PT1_alarm_acknowledged = 0;

		} else if (PT1.Value > PT1.LowLow) {
			FlowLamp.BSVelL = 7;
			FlowLamp.BSLampL = 7;
			FlowLamp.ASVelL = 7;
			FlowLamp.ASLampL = 7;
//			IOdata.PrepChgPT1 = 1;      // [A003] "PT1 교체준비" ON
//			IOdata.PrepChgPT1Alarm = 0;
            if(!PT1_prep_acknowledged) {
                IOdata.PrepChgPT1 = (IOdata.UseBuzzerLamp == 0) ? 1 : 0;
            }
            IOdata.PrepChgPT1Alarm = 0;
            // 알람 단계 플래그는 초기화 (더 심각해졌으므로)
            PT1_alarm_acknowledged = 0;
		} else {
			FlowLamp.BSVelL = 6;
			FlowLamp.BSLampL = 6;
			FlowLamp.ASVelL = 6;
			FlowLamp.ASLampL = 6;
			IOdata.PrepChgPT1 = 0;
//			IOdata.PrepChgPT1Alarm = 1; // [A004] "PT1 교체알람" ON
            if(!PT1_alarm_acknowledged) {
                IOdata.PrepChgPT1Alarm = (IOdata.UseBuzzerLamp == 0) ? 1 : 0;
            }
		}
	}

	// 오른쪽 가스가 공급 중일 때만 PT2 색상 업데이트
	if(IOdata.SupplyGasRSW == 1) {
		if (PT2.Value > PT2.Low) {
			FlowLamp.BSVelR = 8;
			FlowLamp.BSLampR = 8;
			FlowLamp.ASVelR = 8;
			FlowLamp.ASLampR = 8;
			// 알람 해제
			IOdata.PrepChgPT2 = 0;
			IOdata.PrepChgPT2Alarm = 0;
		} else if (PT2.Value > PT2.LowLow) {
			FlowLamp.BSVelR = 7;
			FlowLamp.BSLampR = 7;
			FlowLamp.ASVelR = 7;
			FlowLamp.ASLampR = 7;
			IOdata.PrepChgPT2 = (IOdata.UseBuzzerLamp == 0) ? 1 : 0;
			IOdata.PrepChgPT2Alarm = 0;
		} else {
			FlowLamp.BSVelR = 6;
			FlowLamp.BSLampR = 6;
			FlowLamp.ASVelR = 6;
			FlowLamp.ASLampR = 6;
			// 교체 알람 활성화
			IOdata.PrepChgPT2 = 0;
			IOdata.PrepChgPT2Alarm = (IOdata.UseBuzzerLamp == 0) ? 1 : 0;
		}
	}
	// 🆕 가스량 확인램프 상태 업데이트 (맨 끝에 추가)
	UpdateGasLampStatus();
}

